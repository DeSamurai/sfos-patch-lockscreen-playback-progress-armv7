# - username:source-package-from-openrepos <= 1.0.10
# - source-package-from-official-repo
- sailfish-components-media-qt5 >= 0.9

Prefix: /usr/lib/qt5/qml/Sailfish/Media
DisplayName: Lock screen playback progress(ONLY ARMv7 and I486)
PackageName: sfos-patch-lockscreen-playback-progress
Category: Homescreen
# Category must be one of:
#     Homescreen
#     Browser
#     Camera
#     Calendar
#     Clock
#     Contacts
#     Email
#     Gallery
#     Media
#     Messages
#     Phone
#     Silica
#     Settings
#     Keyboard
#     Others
Keywords:
- Lockscreen
- Media
- Control
- Duration
- Progress
- Playback
- Music
- Song

Maintainer: DeSamurai
Summary: Shows playback progress on the lock screen
Description:
- This patch adds playback progress on the lock screen. The patch relies on Mpris component.
- NOTE!: The only supported apps are Media(Jolla) and gPodder. The supported apps list might be extended in the future.

#DiscussionLink: https://example.org/discussion
